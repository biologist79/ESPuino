#: app.py:182
msgid "Card ID must be exactly 12 digits."
msgstr "L'ID de la carte doit comporter exactement 12 chiffres."

#: app.py:191
#, python-format
msgid "Card %(id)s already exists and is assigned — opening it for editing."
msgstr "La carte %(id)s existe déjà et est assignée — ouverture pour modification."

#: app.py:215
msgid "A stream URL is required for webradio."
msgstr "Une URL de flux est requise pour la webradio."

#: app.py:224
msgid "Please choose a valid play mode."
msgstr "Veuillez choisir un mode de lecture valide."

#: app.py:243
#, python-format
msgid ""
"Some selected files could not be used (missing, or not readable by the "
"container's user) and were skipped: %(paths)s"
msgstr ""
"Certains fichiers sélectionnés n'ont pas pu être utilisés (absents ou non"
" lisibles par l'utilisateur du conteneur) et ont été ignorés : %(paths)s"

#: app.py:252
msgid "At least one audio file is required."
msgstr "Au moins un fichier audio est requis."

#: app.py:256
msgid "This play mode only supports a single file — please select just one."
msgstr ""
"Ce mode de lecture ne prend en charge qu'un seul fichier — veuillez n'en "
"sélectionner qu'un."

#: app.py:262
#, python-format
msgid "Card %(id)s assigned."
msgstr "Carte %(id)s assignée."

#: app.py:278
#, python-format
