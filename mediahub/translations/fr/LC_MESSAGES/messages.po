msgstr ""
"Vous trouverez l'ID de la carte dans l'interface web de l'ESPuino lui-"
"même, en présentant la carte à cet endroit."

#: templates/cards.html:41
msgid "No pending cards."
msgstr "Aucune carte en attente."

#: templates/cards.html:41
msgid "No card known yet — it will show up here once tapped on an ESPuino."
msgstr ""
"Aucune carte connue pour l'instant — elle apparaîtra ici dès qu'elle aura"
" été présentée à un ESPuino."

