msgid "No files selected yet — browse the library below."
msgstr ""
"Aucun fichier sélectionné pour l'instant — parcourez la bibliothèque ci-"
"dessous."

#: templates/card_form.html:48
msgid "Media library"
msgstr "Bibliothèque multimédia"

#: templates/card_form.html:49
msgid ""
"Files come from the library mounted at /media — MediaHub doesn't store "
"its own copies."
msgstr ""
"Les fichiers proviennent de la bibliothèque montée dans /media — MediaHub"
" n'en conserve aucune copie."

#: templates/card_form.html:57
msgid "Use folder"
msgstr "Utiliser le dossier"

