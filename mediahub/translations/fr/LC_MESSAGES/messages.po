msgstr "Actualisation forcée déclenchée pour les %(num)s cartes."

#: app.py:303
#, python-format
msgid ""
"Secure delete: ESPuino (%(esp_id)s) did not confirm the deletion. Card "
"was kept, please retry."
msgstr ""
"Suppression sécurisée : l'ESPuino (%(esp_id)s) n'a pas confirmé la "
"suppression. La carte a été conservée, veuillez réessayer."

#: app.py:305
msgid "unknown"
msgstr "inconnu"

#: app.py:316
#, python-format
msgid "Card %(id)s deleted (%(mode)s)."
