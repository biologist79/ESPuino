#: templates/cards.html:12
msgid "Registered on tap but not yet assigned. Click \"Assign\" to set content."
msgstr ""
"Enregistrée au passage mais pas encore assignée. Cliquez sur « Assigner »"
" pour définir le contenu."

#: templates/cards.html:14
msgid ""
"All cards known to the hub — assigned ones play on next tap, pending ones"
" don't yet."
msgstr ""
"Toutes les cartes connues du hub — les cartes assignées jouent au "
"prochain passage, les cartes en attente pas encore."

#: templates/cards.html:20
msgid "Show all"
msgstr "Tout afficher"

#: templates/cards.html:22
msgid "Pending only"
msgstr "En attente uniquement"

