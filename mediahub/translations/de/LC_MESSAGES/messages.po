msgstr "Force Refresh für alle %(num)s Karten ausgelöst."

#: app.py:359
#, python-format
msgid ""
"Secure delete: ESPuino (%(esp_id)s) did not confirm the deletion. Card "
"was kept, please retry."
msgstr ""
"Secure Delete: Der ESPuino (%(esp_id)s) hat das Löschen nicht bestätigt. "
"Die Karte wurde beibehalten, bitte erneut versuchen."

