#: app.py:229
msgid "Card ID must be exactly 12 digits."
msgstr "Die Karten-ID muss genau 12 Ziffern haben."

#: app.py:233
msgid "Please choose a known ESPuino."
msgstr "Bitte einen bekannten ESPuino wählen."

#: app.py:242
#, python-format
msgid "Card %(id)s is already assigned on this ESPuino — opening it for editing."
msgstr ""
"Karte %(id)s ist auf diesem ESPuino bereits zugewiesen — wird zum "
"Bearbeiten geöffnet."

#: app.py:268
msgid "A stream URL is required for webradio."
msgstr "Für Webradio wird eine Stream-URL benötigt."

#: app.py:277
msgid "Please choose a valid play mode."
msgstr "Bitte einen gültigen Abspielmodus wählen."

#: app.py:296
#, python-format
msgid ""
"Some selected files could not be used (missing, or not readable by the "
"container's user) and were skipped: %(paths)s"
msgstr ""
"Einige ausgewählte Dateien konnten nicht verwendet werden (fehlen oder "
"vom Container-Nutzer nicht lesbar) und wurden übersprungen: %(paths)s"

#: app.py:305
msgid "At least one audio file is required."
msgstr "Mindestens eine Audiodatei wird benötigt."

#: app.py:309
msgid "This play mode only supports a single file — please select just one."
msgstr ""
"Dieser Abspielmodus unterstützt nur eine einzelne Datei — bitte nur eine "
"auswählen."

#: app.py:315
#, python-format
msgid "Card %(id)s assigned."
msgstr "Karte %(id)s zugewiesen."

